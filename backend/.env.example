# Copy to backend/.env and fill in real values.
# Settings load backend/.env automatically (or set variables in your environment).

# PostgreSQL connection string (SQLAlchemy / psycopg2)
# Example: postgresql+psycopg2://user:password@localhost:5432/dbname
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/ecommerce

# Used for signing tokens (generate a long random string for production)
SECRET_KEY=change-me-to-a-long-random-secret

# Groq API key (LLM / LangChain)
GROQ_API_KEY=

# Resend API key (transactional email)
RESEND_API_KEY=

# JWT: optional — defaults are JWT_ALGORITHM=HS256, ACCESS_TOKEN_EXPIRE_MINUTES=30, REFRESH_TOKEN_EXPIRE_DAYS=7

# Product embeddings / similarity search use FAISS (see app.vector_store.faiss_manager).
